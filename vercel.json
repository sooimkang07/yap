{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "outputDirectory": ".",
  "public": true,
  "buildCommand": "echo 'Static site - no build needed'",
  "devCommand": "npx http-server . -p $PORT -c-1",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "microphone=(self)"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/index.html",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/process-notification-jobs",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "api/process-audio.js": {
      "maxDuration": 60
    }
  }
}
