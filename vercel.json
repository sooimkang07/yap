{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node -c server.js",
  "devCommand": "node server.js",
  "framework": null,
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "microphone=(self)"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/process-notification-jobs",
      "schedule": "* * * * *"
    }
  ]
}
